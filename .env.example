# The launcher reads a repo-local `.env` by default. If that file is absent,
# Ubuntu/OCI deployments can also rely on `$HOME/.env` (for example `/home/ubuntu/.env`).
#
# Required Discord bot settings
DISCORD_BOT_TOKEN=
TICKET_PANEL_CHANNEL_ID=
TICKET_CATEGORY_ID=
SUPPORT_TICKET_PANEL_CHANNEL_ID=
SUPPORT_TICKET_CATEGORY_ID=
SUPPORT_MODERATOR_ROLE_ID=
CASH_APP_CASHTAG=$CHANGE_ME

# Required payment parser settings
# Optional: point the public loader at a private, non-repo parser implementation.
# If unset, the bot looks for ../discord_bot_private/Email_Parser_private.py
# relative to the repo root.
DC_BOT_PRIVATE_EMAIL_PARSER_PATH=
PAYMENT_PARSER_GMAIL_ADDRESS=
GMAIL_API_CLIENT_ID=
GMAIL_API_CLIENT_SECRET=
GMAIL_API_REFRESH_TOKEN=
GMAIL_API_TOKEN_URI=https://oauth2.googleapis.com/token

# Runtime defaults that are safe to override on a server
# Private delivery assets are always loaded from /home/ubuntu/discord-bot/assets.
DC_BOT_RUNTIME_DIR=runtime
DC_BOT_DATA_DIR=runtime/data
DC_BOT_STATE_FILE=runtime/data/dc_bot_state.json
DC_BOT_PURCHASE_LOG_FILE=runtime/data/purchase_log.jsonl
DC_BOT_PURCHASE_SYNC_RECOVERY_FILE=runtime/data/purchase_sync_recovery.jsonl

# Deprecated local bot/parser error log paths. Runtime error reports now go to
# stdout and, when configured, the Google Sheets error tab below.
DC_BOT_LOG_DIR=runtime/logs
DC_BOT_LOG_FILE=runtime/logs/dc_bot.log
DC_BOT_PAYMENT_PARSER_LOG_FILE=runtime/logs/payment_parser.log

# Optional Google Sheets sync
# Set either GOOGLE_SHEETS_CREDENTIALS_FILE or GOOGLE_SHEETS_CREDENTIALS_JSON.
# For OCI/Ubuntu secret-based deployments, prefer GOOGLE_SHEETS_CREDENTIALS_JSON.
# GOOGLE_SHEETS_TAB_NAME stores completed purchase records.
# GOOGLE_SHEETS_AUDIT_TAB_NAME stores full purchase-flow audit events.
# GOOGLE_SHEETS_ERROR_TAB_NAME stores structured runtime errors.
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_TAB_NAME=Log
GOOGLE_SHEETS_AUDIT_TAB_NAME=Purchase Audit
GOOGLE_SHEETS_ERROR_TAB_NAME=Bot Errors
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials/google_service_account.json
GOOGLE_SHEETS_CREDENTIALS_JSON=

# Payment parser tuning
PAYMENT_PARSER_EXPECTED_AMOUNT=23.00
PAYMENT_PARSER_ALLOWED_FROM_DOMAINS=cash.app,square.com,squareup.com
PAYMENT_PARSER_ALLOWED_FROM_SUBDOMAINS=
PAYMENT_PARSER_ALLOWED_FROM_ADDRESSES=
PAYMENT_PARSER_ALLOWED_CURRENCY=USD
PAYMENT_PARSER_MAX_MESSAGES_TO_SCAN=50
PAYMENT_PARSER_MAX_MESSAGE_AGE_HOURS=24
PAYMENT_PARSER_NEGATIVE_TIME_BUFFER_MINUTES=2
PAYMENT_PARSER_POSITIVE_TIME_WINDOW_MINUTES=20
PAYMENT_PARSER_REQUIRE_DMARC_WHEN_AVAILABLE=true
PAYMENT_PARSER_REQUIRE_STRICT_ALIGNMENT=true
PAYMENT_PARSER_REQUIRE_STRICT_FROM_ADDRESS_ALLOWLIST=false
PAYMENT_PARSER_REJECT_FORWARDED=true
PAYMENT_PARSER_REJECT_RESENT=true
PAYMENT_PARSER_REJECT_PASTED_STRONG_ONLY=true
PAYMENT_PARSER_CONSUMED_MESSAGE_ID_RETENTION_DAYS=30
